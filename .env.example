# ======================================================
# AI Fairness Platform — Environment Configuration
# ======================================================

# General
ENVIRONMENT=development
APP_NAME="AI Fairness Platform"
APP_VERSION=1.0.0
SECRET_KEY=change-me-to-a-random-64-char-string
LOG_LEVEL=INFO

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fairness_db
POSTGRES_USER=fairness
POSTGRES_PASSWORD=fairness_dev_password
DATABASE_URL=postgresql+asyncpg://fairness:fairness_dev_password@localhost:5432/fairness_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=fairness-experiments

# OpenAI (for AI Fairness Advisor — optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Report generation
REPORTS_OUTPUT_DIR=reports/generated
MAX_REPORT_SIZE_MB=50

# Data
DATA_DIR=datasets
MAX_UPLOAD_SIZE_MB=100
